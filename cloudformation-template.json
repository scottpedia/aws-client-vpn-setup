{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Metadata": {},
  "Resources": {
    "EC2VPC4E833": {
      "Type": "AWS::EC2::VPC",
      "Properties": {
        "CidrBlock": "10.1.0.0/16"
      }
    },
    "EC2S2DKY4": {
      "Type": "AWS::EC2::Subnet",
      "Properties": {
        "CidrBlock": "10.1.0.0/16",
        "VpcId": {
          "Ref": "EC2VPC4E833"
        },
        "AvailabilityZone": {
          "Fn::Select": [
            "0",
            {
              "Fn::GetAZs": ""
            }
          ]
        }
      }
    },
    "EC2RTC7I3": {
      "Type": "AWS::EC2::RouteTable",
      "Properties": {
        "VpcId": {
          "Ref": "EC2VPC4E833"
        }
      },
      "DependsOn": [
        "EC2S2DKY4"
      ]
    },
    "EC2IG4CT3V": {
      "Type": "AWS::EC2::InternetGateway",
      "Properties": {},
      "Metadata": {
        "DependsOn": [
          "EC2VPC4E833"
        ]
      }
    },
      "EC2VPCG147NO": {
        "Type": "AWS::EC2::VPCGatewayAttachment",
        "Properties": {
          "VpcId": {
            "Ref": "EC2VPC4E833"
          },
          "InternetGatewayId": {
            "Ref": "EC2IG4CT3V"
          }
        }
      },
      "EC2SRTAKX44": {
        "Type": "AWS::EC2::SubnetRouteTableAssociation",
        "Properties": {
          "RouteTableId": {
            "Ref": "EC2RTC7I3"
          },
          "SubnetId": {
            "Ref": "EC2S2DKY4"
          }
        }
      },
      "EC2R1LNRL": {
        "Type": "AWS::EC2::Route",
        "Properties": {
          "DestinationCidrBlock": "0.0.0.0/0",
          "RouteTableId": {
            "Ref": "EC2RTC7I3"
          },
          "GatewayId": {
            "Ref": "EC2IG4CT3V"
          }
        },
        "DependsOn": [
          "EC2IG4CT3V",
          "EC2RTC7I3",
          "EC2VPCG147NO"
        ]
      },
      "EC2CVE11MMM": {
        "Type": "AWS::EC2::ClientVpnEndpoint",
        "Properties": {
          "AuthenticationOptions": [
            {
              "MutualAuthentication": {
                "ClientRootCertificateChainArn": {
                  "Ref": "ClientCertificateArn"
                }
              },
              "Type": "certificate-authentication"
            }
          ],
          "ClientCidrBlock": "10.0.0.0/16",
          "ConnectionLogOptions": {
            "Enabled": false
          },
          "DnsServers": [
            "8.8.8.8"
          ],
          "ServerCertificateArn": {
            "Ref": "ServerCertificateArn"
          },
          "SplitTunnel": {
            "Ref": "isSplitTunnelled"
          },
          "TransportProtocol": {
            "Ref": "NetworkProtocol"
          },
          "VpcId": {
            "Ref": "EC2VPC4E833"
          },
          "VpnPort": {
            "Ref": "VpnPort"
          }
        },
        "DependsOn": [
          "EC2IG4CT3V",
          "EC2S2DKY4"
        ]
      },
      "EC2CVAR34CED": {
        "Type": "AWS::EC2::ClientVpnAuthorizationRule",
        "Properties": {
          "ClientVpnEndpointId": {
            "Ref": "EC2CVE11MMM"
          },
          "TargetNetworkCidr": "0.0.0.0/0",
          "AuthorizeAllGroups": true
        },
        "DependsOn": [
          "EC2IG4CT3V"
        ]
      }
    },
    "Parameters": {
      "ClientCertificateArn": {
        "Type": "String",
        "Description": "The ARN of the pre-imported client-side certificate found in ACM."
      },
      "ServerCertificateArn": {
        "Type": "String",
        "Description": "The ARN of the pre-imported server-side certificate found in ACM."
      },
      "isSplitTunnelled": {
        "Type": "String",
        "AllowedValues": [
          "true",
          "false"
        ],
        "Default": "false",
        "Description": "If VPN endpoint enables split tunneling. Select \"false\" if you don't know what it is."
      },
      "NetworkProtocol": {
        "Type": "String",
        "Description": "The network protocol used by the VPN server. Allowed values are TCP and UDP. Choose TCP for a more stable connection. Choose UDP for a faster connection.",
        "AllowedValues": [
          "tcp",
          "udp"
        ],
        "Default": "udp"
      },
      "VpnPort": {
        "Type": "Number",
        "Description": "The VPN port to use, either 443 or 1194.",
        "AllowedValues": [
          443,
          1194
        ],
        "Default": 443
      }
    },
    "Outputs": {
      "ClientVPNEndpointId": {
        "Value": {
          "Ref": "EC2CVE11MMM"
        },
        "Description": "The Client VPN Endpoint ID"
      },
      "SubnetId": {
        "Value": {
          "Ref": "EC2S2DKY4"
        },
        "Description": "The Subnet Id"
      }
    }
  }